---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Travel">

  <p class="font-label text-xs mb-4 tracking-widest" style="color: var(--accent);">TRAVEL</p>
  <h1 class="font-display mb-4" style="font-size: 2.5rem;">Places I've Been</h1>
  <p class="text-lg mb-16 max-w-xl" style="color: var(--muted); line-height: 1.7;">
    Stories, photos, and places worth returning to. More coming soon.
  </p>

  <div
    style="border: 1px solid var(--border); background: var(--surface);"
    class="rounded-lg p-16 text-center"
  >
    <p class="font-display text-2xl mb-2" style="color: var(--muted);">Coming soon</p>
    <p class="text-sm" style="color: var(--muted);">Travel stories and photos are on the way.</p>
  </div>

</Layout>
