---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Home' } = Astro.props;

const navLinks = [
  { href: '/',         label: 'About' },
  { href: '/resume',   label: 'Resume' },
  { href: '/travel',   label: 'Travel' },
  { href: '/projects', label: 'Projects' },
];

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Justin M. Hemp — Operations and CX Leader based in Portland, OR." />
    <title>{title === 'Home' ? 'Justin M. Hemp' : `${title} · Justin M. Hemp`}</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="min-h-screen flex flex-col">

    <!-- ── Navigation ── -->
    <header style="border-bottom: 1px solid var(--border); background-color: var(--bg);" class="sticky top-0 z-50">
      <nav class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="font-display text-xl" style="color: var(--text);">JH</a>
        <ul class="flex gap-8">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-sm font-medium tracking-wide"
                style={currentPath === link.href
                  ? 'color: var(--accent);'
                  : 'color: var(--muted);'}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <!-- ── Page Content ── -->
    <main class="flex-1 max-w-4xl mx-auto px-6 py-16 w-full">
      <slot />
    </main>

    <!-- ── Footer ── -->
    <footer style="border-top: 1px solid var(--border);" class="py-8">
      <div class="max-w-4xl mx-auto px-6 flex items-center justify-between">
        <p class="text-sm font-label" style="color: var(--muted);">© 2026 Justin M. Hemp</p>
        <a
          href="https://linkedin.com/in/justinhemp"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium"
          style="color: var(--muted);"
        >
          LinkedIn ↗
        </a>
      </div>
    </footer>

  </body>
</html>
